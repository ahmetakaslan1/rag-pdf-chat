# ================================
# UYGULAMA
# ================================
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# ================================
# VERİTABANI (PostgreSQL + pgvector)
# ================================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=rag_chat_db

# ================================
# REDIS (BullMQ + Cache)
# ================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ================================
# JWT (Çift Token Mimarisi)
# ================================
JWT_ACCESS_SECRET=your_access_secret_here_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_here_min_32_chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ================================
# DEPOLAMA (Strategy Pattern)
# ================================
STORAGE_TYPE=local

# Yerel Disk (STORAGE_TYPE=local iken kullanılır)
LOCAL_UPLOAD_DIR=./uploads
LOCAL_BASE_URL=http://localhost:3000

# Amazon S3 (STORAGE_TYPE=s3 iken kullanılır)
# S3_BUCKET_NAME=rag-pdf-storage
# S3_REGION=eu-central-1
# S3_ACCESS_KEY=AKIAIOSFODNN7EXAMPLE
# S3_SECRET_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# ================================
# GEMİNİ API
# ================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_EMBEDDING_MODEL=text-embedding-004
GEMINI_CHAT_MODEL=gemini-2.5-flash

# ================================
# THROTTLE (Rate Limit — Misafir)
# ================================
THROTTLE_TTL=3600
THROTTLE_LIMIT=3
